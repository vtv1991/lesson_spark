# ── Client (browser) ──────────────────────────────────────────────
# Supabase project — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public base URL of the app (used for share/preview links).
# Local dev can leave this blank (falls back to window.origin).
VITE_PUBLIC_APP_URL=https://your-project.vercel.app

# ── Server (never exposed to the browser) ─────────────────────────
# Same Supabase URL, readable server-side.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Service role key — Dashboard → Project Settings → API → service_role.
# SECRET. Powers OAuth token storage + MCP acting on behalf of a user.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL, server-side (OAuth issuer + preview links).
PUBLIC_APP_URL=https://your-project.vercel.app

# Coachio key used by the MCP server to generate lessons from Claude/ChatGPT.
COACHIO_API_KEY=your-coachio-key
